# Application
VECTORDB_APP_NAME=vectordb
VECTORDB_ENVIRONMENT=development
VECTORDB_DEBUG=false
VECTORDB_HOST=0.0.0.0
VECTORDB_PORT=8000

# Logging
VECTORDB_LOG_LEVEL=INFO
VECTORDB_LOG_FORMAT=text

# Embeddings
VECTORDB_EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTORDB_EMBEDDING_CACHE_ENABLED=true
VECTORDB_EMBEDDING_CACHE_SIZE=1024
